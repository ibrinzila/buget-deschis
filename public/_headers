# Headers pentru Cohesion Lab
# Laboratorul de Tehnologie Civică și Coeziune Socială
# Configurație pentru Cloudflare Pages

# Headers globale pentru toate paginile
/*
  # Security Headers
  
  # HTTP Strict Transport Security (HSTS)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Content Security Policy (CSP)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; media-src 'self'; object-src 'none'; child-src 'none'; worker-src 'none'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'
  
  # X-Frame-Options pentru protecție împotriva clickjacking
  X-Frame-Options: DENY
  
  # X-Content-Type-Options pentru prevenirea MIME sniffing
  X-Content-Type-Options: nosniff
  
  # X-XSS-Protection pentru protecție XSS în browsere vechi
  X-XSS-Protection: 1; mode=block
  
  # Referrer Policy pentru controlul informațiilor de referrer
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions Policy pentru limitarea accesului la API-uri browser
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), serial=(), bluetooth=(), magnetometer=(), gyroscope=(), accelerometer=()
  
  # Cross-Origin-Embedder-Policy pentru securitate cross-origin
  Cross-Origin-Embedder-Policy: require-corp
  
  # Cross-Origin-Opener-Policy pentru izolarea proceselor
  Cross-Origin-Opener-Policy: same-origin
  
  # Cross-Origin-Resource-Policy pentru controlul accesului la resurse
  Cross-Origin-Resource-Policy: same-origin

# Headers pentru fișiere statice (performanță și cache)
/assets/*
  # Cache pentru 1 an pentru asset-uri statice
  Cache-Control: public, max-age=31536000, immutable
  
  # Compresie
  Content-Encoding: gzip
  
  # CORS pentru asset-uri
  Access-Control-Allow-Origin: https://cohesionlab.org

# Headers specifice pentru imagini SVG
/assets/*.svg
  # Tip de conținut corect pentru SVG
  Content-Type: image/svg+xml
  
  # Cache pentru 6 luni
  Cache-Control: public, max-age=15552000
  
  # Securitate specifică SVG
  X-Content-Type-Options: nosniff

# Headers pentru date JSON
/data/*.json
  # Tip de conținut JSON
  Content-Type: application/json; charset=utf-8
  
  # Cache pentru 1 oră (date care se actualizează)
  Cache-Control: public, max-age=3600, must-revalidate
  
  # CORS pentru acces la date
  Access-Control-Allow-Origin: https://cohesionlab.org
  Access-Control-Allow-Methods: GET
  Access-Control-Allow-Headers: Content-Type

# Headers pentru security.txt
/.well-known/security.txt
  # Tip de conținut text
  Content-Type: text/plain; charset=utf-8
  
  # Cache pentru 1 zi
  Cache-Control: public, max-age=86400
  
  # Permitere accesul pentru toate originile (standard security.txt)
  Access-Control-Allow-Origin: *

# Headers pentru robots.txt și sitemap
/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=86400

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=86400

# Headers pentru documentele publice
/public/*
  # Cache pentru 1 săptămână pentru documente
  Cache-Control: public, max-age=604800
  
  # Forțează descărcarea pentru PDF-uri
  Content-Disposition: attachment
  
  # Securitate pentru documente
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY

# Headers pentru pagini HTML
/*.html
  # Cache pentru 1 oră cu revalidare
  Cache-Control: public, max-age=3600, must-revalidate
  
  # Tip de conținut HTML cu charset
  Content-Type: text/html; charset=utf-8

# Redirecționări (handled by Cloudflare Redirect Rules, dar menționate aici pentru documentație)
# cohesionlab.tech -> cohesionlab.org (301 redirect permanent)
# www.cohesionlab.org -> cohesionlab.org (301 redirect permanent)

# Headers pentru prevenirea indexării fișierelor administrative
/_*
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet

# Headers pentru favicon
/favicon.*
  Cache-Control: public, max-age=31536000
  Content-Type: image/svg+xml

# Headers pentru performanță - preconnect și dns-prefetch
/*
  # Preconnect la domeniile proprii
  Link: <https://cohesionlab.org>; rel=preconnect
  
  # Early hints pentru asset-uri critice
  Link: </assets/styles.css>; rel=preload; as=style
  Link: </assets/logo.svg>; rel=preload; as=image

# Server push pentru Cloudflare (dacă este disponibil)
/
  Link: </assets/styles.css>; rel=preload; as=style
  Link: </assets/favicon.svg>; rel=preload; as=image

# Headers pentru API rate limiting (viitor)
/api/*
  X-RateLimit-Limit: 100
  X-RateLimit-Window: 3600
